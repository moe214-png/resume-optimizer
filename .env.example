DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_REQUEST_TIMEOUT=60

# Set this before sharing the app with friends.
APP_PASSWORD=change-me
APP_SECRET_KEY=replace-with-a-long-random-string

# Delete generated Word files older than this many seconds. Default: 24 hours.
OUTPUT_TTL_SECONDS=86400
